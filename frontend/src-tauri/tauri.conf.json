{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OKRA 长期记忆投资工作台",
  "version": "0.1.0",
  "identifier": "com.okra.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OKRA 长期记忆投资工作台",
        "width": 1560,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
